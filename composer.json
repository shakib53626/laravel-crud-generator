{
    "name": "shakib53626/laravel-crud-generator",
    "description": "A Laravel package to generate CRUD scaffold (Migration, Model, Controller, Requests, Resource) with one command.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shakib",
            "email": "shakib@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Shakib53626\\CrudGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shakib53626\\CrudGenerator\\CrudGeneratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
